{
  "d1": {
    "configPath": "./wrangler.jsonc",
    "binding": "DB",
    "remote": true,
    "persistTo": false
  },
  "schema": {
    "include": ["notes"]
  },
  "client": {
    "databaseName": "sync-engine-v2-manual-row-sync"
  },
  "server": {
    "module": "./app/sync/server.ts",
    "exportName": "syncServer"
  },
  "routes": {
    "appDir": "./app",
    "basePath": "/api/sync"
  },
  "output": {
    "config": "./app/sync/sync.generated.ts",
    "serviceWorker": "./public/sync-engine-v2.sw.js"
  },
  "serviceWorker": {
    "syncTag": "manual-row-sync"
  }
}
