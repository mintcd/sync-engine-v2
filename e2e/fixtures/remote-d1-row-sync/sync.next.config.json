{
  "d1": {
    "configPath": "./wrangler.jsonc",
    "binding": "DB",
    "remote": true,
    "persistTo": false
  },
  "schema": {
    "include": [
      "notes"
    ]
  },
  "client": {
    "databaseName": "sync-engine-remote-d1-row-sync"
  },
  "server": {
    "module": "./src/sync/server.ts",
    "exportName": "syncServer"
  },
  "routes": {
    "appDir": "./app",
    "basePath": "/api/sync"
  },
  "output": {
    "config": "./src/sync/sync.generated.ts",
    "serviceWorker": "./public/sync-engine.sw.js"
  },
  "serviceWorker": {
    "syncTag": "remote-d1-row-sync"
  }
}