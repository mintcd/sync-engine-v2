{
  "name": "@mintcd/sync-engine-v2",
  "version": "0.0.0-development",
  "private": true,
  "description": "A correctness-first core for replicating a canonical operation log.",
  "type": "module",
  "sideEffects": false,
  "bin": {
    "sync-engine-v2": "./bin/sync-engine.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./indexeddb": {
      "types": "./dist/indexeddb/index.d.ts",
      "import": "./dist/indexeddb/index.js"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "import": "./dist/schema/index.js"
    }
  },
  "files": [
    "bin",
    "dist",
    "docs",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test test/*.test.js",
    "check": "npm run typecheck && npm test",
    "prepack": "npm run build"
  },
  "peerDependencies": {
    "wrangler": ">=4.37.0"
  },
  "peerDependenciesMeta": {
    "wrangler": {
      "optional": true
    }
  },
  "devDependencies": {
    "fake-indexeddb": "6.2.5",
    "typescript": "5.8.3"
  },
  "engines": {
    "node": ">=20"
  }
}
