{
  "name": "@mintcd/sync-engine",
  "version": "1.0.0",
  "description": "A correctness-first core for replicating a canonical operation log.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mintcd/sync-engine.git"
  },
  "bugs": {
    "url": "https://github.com/mintcd/sync-engine/issues"
  },
  "homepage": "https://github.com/mintcd/sync-engine#readme",
  "keywords": [
    "sync",
    "replication",
    "local-first",
    "indexeddb",
    "cloudflare-d1",
    "nextjs"
  ],
  "type": "module",
  "sideEffects": false,
  "bin": {
    "sync-engine": "bin/sync-engine"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./indexeddb": {
      "types": "./dist/indexeddb/index.d.ts",
      "import": "./dist/indexeddb/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js"
    },
    "./client/react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "import": "./dist/schema/index.js"
    },
    "./next": {
      "types": "./dist/next/index.d.ts",
      "import": "./dist/next/index.js"
    }
  },
  "files": [
    "bin",
    "dist",
    "docs",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "npm run dev:example",
    "dev:example": "npm run sync:next:example && cd examples/next-d1-notes && vinext dev --port 3000",
    "sync:next": "npm run sync:next:example",
    "sync:next:example": "npm run build && node bin/sync-engine next examples/next-d1-notes/sync.next.config.json --force",
    "build": "node scripts/build.mjs && tsc -p tsconfig.json --emitDeclarationOnly --noEmit false",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test test/*.test.js e2e/*.test.js",
    "test:e2e": "npm run build && node --test e2e/*.test.js",
    "test:e2e:browser": "npm run build && node --test e2e/browser/*.test.js",
    "test:e2e:remote-d1": "npm run build && node --test e2e/remote-d1/*.test.js",
    "check": "npm run typecheck && npm test",
    "prepack": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "wrangler": ">=4.37.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "wrangler": {
      "optional": true
    }
  },
  "dependencies": {
    "esbuild": "0.28.1"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.45.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^25.9.5",
    "@types/react": "^19.2.17",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitejs/plugin-rsc": "^0.5.28",
    "fake-indexeddb": "6.2.5",
    "next": "^16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-server-dom-webpack": "^19.2.7",
    "typescript": "5.8.3",
    "vinext": "^0.1.8",
    "vite": "^8.1.5",
    "wrangler": "^4.112.0"
  },
  "engines": {
    "node": ">=20"
  }
}